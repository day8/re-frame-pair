{
  "name": "@day8/re-frame-pair",
  "version": "0.1.0-beta.4",
  "description": "Pair-program with a live re-frame application. A Claude Code Skill for the day8 stack (re-frame + re-frame-10x + re-com + shadow-cljs).",
  "keywords": [
    "claude-code",
    "claude-code-skill",
    "claude-code-plugin",
    "re-frame",
    "re-frame-10x",
    "re-com",
    "shadow-cljs",
    "clojurescript",
    "pair-programming",
    "day8"
  ],
  "homepage": "https://github.com/day8/re-frame-pair",
  "bugs": {
    "url": "https://github.com/day8/re-frame-pair/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/day8/re-frame-pair.git"
  },
  "license": "MIT",
  "author": "day8 (https://github.com/day8)",
  "scripts": {
    "test": "shadow-cljs compile runtime-test && node out/runtime-test.js && OPS_NO_AUTO_RUN=1 bb tests/ops_smoke.bb && bb tests/skill_recipe_smoke.bb",
    "test:ops": "OPS_NO_AUTO_RUN=1 bb tests/ops_smoke.bb",
    "test:skill-recipe": "bb tests/skill_recipe_smoke.bb",
    "prepublishOnly": "npm test"
  },
  "devDependencies": {
    "shadow-cljs": "3.2.0"
  },
  "files": [
    "SKILL.md",
    "README.md",
    "LICENSE",
    "scripts/",
    ".claude-plugin/",
    "docs/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
