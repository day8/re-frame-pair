;; shadow-cljs config for the runtime-test build (rfp-8sg).
;;
;; Runs as a node-test target so CI doesn't need a browser. The tests
;; live in tests/runtime/runtime_test.cljs and exercise the pure helpers
;; in scripts/re_frame_pair/runtime.cljs. trace-enabled? + goog.DEBUG
;; are set true so anything that branches on them takes the live path.
;;
;; Run locally:
;;   npm install
;;   npx shadow-cljs compile runtime-test && node out/runtime-test.js
;;
;; The fixture (tests/fixture/) is a separate build with its own
;; shadow-cljs.edn — it's a browser app, this is a node test runner.

{:deps  true

 :builds
 {:runtime-test
  {:target           :node-test
   :output-to        "out/runtime-test.js"
   :ns-regexp        "-test$"
   :compiler-options
   {:closure-defines {re-frame.trace.trace-enabled? true
                      goog.DEBUG                    true}}}

  ;; Consumer-side verification: builds re-frame-pair.runtime in
  ;; :advanced together with day8.re-frame-10x.public, then asserts the
  ;; documented un-suffixed contract path
  ;; (goog.global.day8.re_frame_10x.public.<name>) resolves — i.e. that
  ;; the upstream `public$` mirror block survives :advanced compilation
  ;; of the *consumer* build. The :public-advanced probe inside
  ;; re-frame-10x covers the producer build separately; this one closes
  ;; the loop on re-frame-pair's side. Activate the deps.edn
  ;; :probe-advanced alias when running:
  ;;   npx shadow-cljs -A:probe-advanced compile probe-advanced
  ;;   node out/probe-advanced.js
  :probe-advanced
  {:target           :node-script
   :main             probe-advanced/-main
   :output-to        "out/probe-advanced.js"
   :compiler-options {:optimizations :advanced
                      :closure-defines {re-frame.trace.trace-enabled? true
                                        goog.DEBUG                    true}}}}}
