;; Fixture deps. Pulled via :local/root from sibling repos so the
;; spike exercises the *current* source of each library — the whole
;; reason re-frame-pair exists is to verify runtime.cljs maps to
;; current internals. If you're running this fixture outside the
;; co-located dev layout, switch these to :mvn/version pins.

{;; ../../scripts puts re-frame-pair.runtime on the classpath at
 ;; compile time so the fixture can :refer-macros [reg-event-db ...]
 ;; from re-frame-pair.runtime (rfp-rsg / Path 3 in
 ;; docs/handler-source-meta.md). Downstream apps templating off
 ;; this fixture would normally consume re-frame-pair as a published
 ;; lib — for the in-tree fixture we point at scripts/ directly.
 :paths ["src" "../../scripts"]
 :deps  {re-frame/re-frame           {:local/root "../../../re-frame"}
         day8.re-frame/re-frame-10x  {:local/root "../../../re-frame-10x"}
         re-com/re-com               {:local/root "../../../re-com"}
         ;; rfp-mkf — :local/root path, not a clojars coord. Wires
         ;; the fixture into the :debux/code bridge so runtime.cljs's
         ;; epoch coercion gets exercised end-to-end against a real
         ;; fn-traced handler (Phase 1 in rfp-hjj was unit-tested
         ;; only). Downstream apps templating off this fixture would
         ;; declare their own day8.re-frame/tracing dep — see the
         ;; README's "Optional re-frame-debux integration" section.
         day8.re-frame/tracing       {:local/root "../../../re-frame-debux"}
         reagent/reagent             {:mvn/version "1.2.0"}
         thheller/shadow-cljs        {:mvn/version "3.2.0"}
         ;; re-com's deps.edn keeps its transitives in :demo / :provided
         ;; aliases — :local/root doesn't carry aliases, so we have to
         ;; restate them here. Versions match re-com's :demo alias.
         ;; Only the deps actually used by src/re_com/* (validate.cljs +
         ;; datepicker.cljs need cljs-time; typeahead.cljs needs
         ;; core.async). storage-atom / transit-cljs / secretary are
         ;; demo-only and stay out.
         com.andrewmcveigh/cljs-time {:mvn/version "0.5.2"}
         org.clojure/core.async      {:mvn/version "1.3.618"}}}
