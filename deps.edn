;; deps for the runtime-test shadow-cljs build (rfp-8sg). The unit
;; tests under tests/runtime/ exercise the pure helpers in
;; scripts/re_frame_pair/runtime.cljs (re-com classification,
;; rc-src parsing, predicate matching, coerce-epoch shape, etc.) —
;; all without a live browser or re-frame app.
;;
;; The fixture (tests/fixture/) has its own deps.edn. We don't share
;; this one with it because the fixture pulls every dep transitively
;; (10x, re-com) and the runtime-tests only need the re-frame surface
;; that runtime.cljs requires.

{:paths ["scripts" "tests/runtime"]
 :deps  {;; Pinned to mvn versions so CI can build without
         ;; needing the sibling repos co-located. The fixture's
         ;; deps.edn uses :local/root because it's exercising
         ;; *current* source — but the runtime-test build only
         ;; cares about the public re-frame surface that runtime.cljs
         ;; requires (re-frame.core, re-frame.db, re-frame.registrar,
         ;; re-frame.subs, re-frame.trace), which is stable.
         re-frame/re-frame    {:mvn/version "1.4.5"}
         reagent/reagent      {:mvn/version "1.2.0"}
         ;; shadow-cljs.edn here uses ':deps true', which delegates
         ;; classpath construction to this file — so shadow-cljs must
         ;; be on the dep list explicitly. Matches tests/fixture/deps.edn
         ;; and package.json devDependencies.
         thheller/shadow-cljs {:mvn/version "3.2.0"}}

 ;; The :probe-advanced alias activates the consumer-side verification
 ;; probe at tests/probe/probe_advanced.cljs — the gate that asserts the
 ;; documented un-suffixed `goog.global.day8.re_frame_10x.public.<name>`
 ;; path resolves under re-frame-pair's :advanced consumer build.
 ;; re-frame-10x is pulled via :local/root because the probe must build
 ;; against CURRENT 10x source (the upstream `public$` mirror block has
 ;; to be present, or the path resolves to nil and the probe rightly
 ;; fails).
 ;;
 ;; Run via:
 ;;   npx shadow-cljs -A:probe-advanced compile probe-advanced
 ;;   node out/probe-advanced.js
 ;;
 ;; Not on the default classpath because it requires re-frame-10x to be
 ;; co-located on disk — the runtime-test build (npm test) is purposely
 ;; portable for CI without sibling repos and must not depend on it.
 :aliases
 {:probe-advanced
  {:extra-paths ["tests/probe"]
   :extra-deps  {day8.re-frame/re-frame-10x
                 ;; Exclude UI-side transitive deps. The probe only
                 ;; loads day8.re-frame-10x.public, which doesn't pull
                 ;; the panel/highlighting machinery — but shadow-cljs
                 ;; scans the entire classpath for cljsjs deps and
                 ;; auto-installs their npm shadows (--save) regardless
                 ;; of whether anything `:require`s them. Without these
                 ;; exclusions, `highlight.js` gets written into prod
                 ;; `dependencies` in package.json on every build run,
                 ;; polluting the published @day8/re-frame-pair package.
                 {:local/root "../re-frame-10x"
                  :exclusions [cljsjs/highlight
                               superstructor/re-highlight]}}}}}
